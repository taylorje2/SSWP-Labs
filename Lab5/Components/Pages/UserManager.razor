@page "/user-manager"
@using Lab5.Services
@using Lab5.Models
@inject ILibraryService LibraryService

<title>User Manager</title>

<div class="container">
    @* add user to list *@
    <h3 class="text-center">User Manager</h3>
    <div class="card shadow-sm">
        <h5 class="p-3">Add New User:</h5>
        <div class="mb-3 p-3">
            <input @bind="newUser.Name" class="form-control mb-2" placeholder="Name" />
            <input @bind="newUser.Email" class="form-control mb-2" placeholder="Email" />
            <button class="btn btn-success" @onclick="AddNewUser">Add User</button>
        </div>
    </div>

    @* view users *@
    <div class="card shadow-sm p-3 mt-3">
        <h5 class="mt-3">User List</h5>
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in LibraryServices.users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>
                            <a href="/edit-user/@user.Id" class="btn btn-primary">Edit</a>
                        </td>
                        <td><button type="button" class="btn btn-danger" @onclick="() => RemoveUser(user.Id)">Delete</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    // object for new user
    User newUser = new User();

    // Add user
    void AddNewUser()
    {
        // call add user method
        LibraryService.AddUser(newUser);

        newUser = new User();
    }

    // Edit user
    void UpdateUser(int id)
    {
        // call edit user method
        LibraryService.EditUser(id, newUser);

        newUser = new User();
    }

    // Delete user
    void RemoveUser(int id)
    {
        // call delete user method
        LibraryService.DeleteUser(id);
    }
}
