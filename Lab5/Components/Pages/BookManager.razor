@page "/"
@using Lab5.Services
@using Lab5.Models
@inject ILibraryService LibraryService

<title>Book Manager</title>

<div class="container">
    @* add book to list *@
    <h3 class="text-center">Book Manager</h3>
    <div class="card shadow-sm">
        <h5 class="p-3">Add New Book:</h5>
        <div class="mb-3 p-3">
            <input @bind="newBook.Title" class="form-control mb-2" placeholder="Title" />
            <input @bind="newBook.Author" class="form-control mb-2" placeholder="Author" />
            <input @bind="newBook.ISBN" class="form-control mb-2" placeholder="ISBN" />
            <button class="btn btn-success" @onclick="AddNewBook">Add Book</button>
        </div>
    </div>

    @* view books *@
    <div class="card shadow-sm p-3 mt-3">
        <h5 class="mt-3">Book List</h5>
        @* Table for all books*@
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>ISBN</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in LibraryServices.books)
                {
                    <tr>
                        <td>@book.Id</td>
                        <td>@book.Title</td>
                        <td>@book.Author</td>
                        <td>@book.ISBN</td>
                        <td>
                            <a href="/edit-book/@book.Id" class="btn btn-primary">Edit</a>
                        </td>
                        <td><button type="button" class="btn btn-danger" @onclick="() => RemoveBook(book.Id)">Delete</button></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    // object for new book
    Book newBook = new Book();

    // Add book
    void AddNewBook()
    {
        // call add book method
        LibraryService.AddBook(newBook);

        newBook = new Book();
    }

    // Edit book
    void UpdateBook(int id)
    {
        // call edit book method
        LibraryService.EditBook(id, newBook);

        newBook = new Book();
    }
    // Delete book
    void RemoveBook(int id)
    {
        // call delete book method
        LibraryService.DeleteBook(id);
    }
}
