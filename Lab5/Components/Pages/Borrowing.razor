@page "/borrow"
@using Lab5.Services
@using Lab5.Models
@inject ILibraryService LibraryService

<title>Borrowing System</title>
<div class="container">
    <h3 class="text-center">Borrowing System</h3>
    <div class="card shadow-sm p-3 mt-3">
        <h5 class="mt-3">Unavailable Books</h5>
        <table class="table table-striped table-hover">
            <thead>
                <th>User</th>
                <th>Book Title</th>
                <th>Option</th>
            </thead>
           <tbody>
                @foreach (var entry in LibraryServices.borrowedBooks)
                {
                    @foreach (var book in entry.Value)
                    {
                        <tr>
                            <td>@entry.Key.Name</td>
                            <td>@book.Title</td>
                            <td>
                                <button class="btn btn-warning bt-sm" @onclick="() => LibraryService.ReturnBook(entry.Key, book)">Return Book</button>
                            </td>
                        </tr>
                    }
                }
           </tbody>
        </table>
    </div>

    <div class="card shadow-sm p-3 mt-3">
        <h5 class="mt-3">Borrowing Form</h5>
        <div class="row bg-light">
            <div class="col-md-4">
                <label>Select Book:</label>
                <select @bind="selectBook" class="form-control">
                    <option value="0">-- Available Books --</option>
                    @foreach (var b in LibraryServices.books)
                    {
                        <option value="@b.Id">@b.Title (@b.Author)</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label>Select User:</label>
                <select @bind="selectUser" class="form-control">
                    <option value="0">-- Members --</option>
                    @foreach (var u in LibraryServices.users)
                    {
                        <option value="@u.Id">@u.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4 align-items-end d-flex">
                <button class="btn btn-primary" @onclick="Borrow">Confirm</button>
            </div>
        </div>
    </div>
</div>

@code {
    // variables for book and user selections
    int selectBook;
    int selectUser;

    /// <summary>
    /// method for borrowing books
    /// </summary>
    void Borrow()
    {
        // if the selections are greater than 0, save selection
        if (selectBook > 0 && selectUser > 0)
        {
            LibraryService.BorrowBook(selectBook, selectUser);
            selectBook = 0;
            selectUser = 0;
        }
    }
}
